{"id": "health_get", "method": "GET", "path": "/health", "headers": {}, "body": null, "expect_note": "200 static JSON {status:ok}"}
{"id": "health_head", "method": "HEAD", "path": "/health", "headers": {}, "body": null, "expect_note": "HEAD on GET route -> 200 empty body"}
{"id": "health_post_405", "method": "POST", "path": "/health", "headers": {}, "body": null, "expect_note": "405 Method Not Allowed, Allow header present"}
{"id": "health_delete_405", "method": "DELETE", "path": "/health", "headers": {}, "body": null, "expect_note": "405 Method Not Allowed"}
{"id": "health_options_405", "method": "OPTIONS", "path": "/health", "headers": {}, "body": null, "expect_note": "OPTIONS -> 405 (no CORS middleware)"}
{"id": "health_put_405", "method": "PUT", "path": "/health", "headers": {}, "body": null, "expect_note": "405"}
{"id": "get_user_1", "method": "GET", "path": "/users/1", "headers": {}, "body": null, "expect_note": "200 {id:1,name:alice,age:30}"}
{"id": "get_user_2", "method": "GET", "path": "/users/2", "headers": {}, "body": null, "expect_note": "200 {id:2,name:bob,age:25}"}
{"id": "get_user_3", "method": "GET", "path": "/users/3", "headers": {}, "body": null, "expect_note": "200 {id:3,name:carol,age:40}"}
{"id": "get_user_404", "method": "GET", "path": "/users/9999", "headers": {}, "body": null, "expect_note": "quackapi returns 200 empty; FastAPI returns 200 null - both return 200 but body differs"}
{"id": "get_user_head", "method": "HEAD", "path": "/users/1", "headers": {}, "body": null, "expect_note": "HEAD treated as GET -> 200 no body"}
{"id": "get_user_bad_int", "method": "GET", "path": "/users/abc", "headers": {}, "body": null, "expect_note": "422 int_parsing loc=[path,id]"}
{"id": "get_user_bad_float", "method": "GET", "path": "/users/1.5", "headers": {}, "body": null, "expect_note": "422 int_parsing (1.5 is not int)"}
{"id": "get_user_bad_negative", "method": "GET", "path": "/users/-1", "headers": {}, "body": null, "expect_note": "200 or empty - no min constraint, -1 is valid int"}
{"id": "get_user_overflow", "method": "GET", "path": "/users/99999999999999999999", "headers": {}, "body": null, "expect_note": "422 int_parsing on overflow"}
{"id": "get_user_zero", "method": "GET", "path": "/users/0", "headers": {}, "body": null, "expect_note": "200 or empty - 0 is valid int"}
{"id": "get_user_leading_zero", "method": "GET", "path": "/users/01", "headers": {}, "body": null, "expect_note": "422 or 200 - leading zero handling differs"}
{"id": "get_user_space", "method": "GET", "path": "/users/%20", "headers": {}, "body": null, "expect_note": "422 int_parsing for URL-encoded space"}
{"id": "list_users", "method": "GET", "path": "/users", "headers": {}, "body": null, "expect_note": "200 JSON array of 3 users"}
{"id": "list_users_head", "method": "HEAD", "path": "/users", "headers": {}, "body": null, "expect_note": "HEAD -> 200 empty body"}
{"id": "list_users_trailing_slash", "method": "GET", "path": "/users/", "headers": {}, "body": null, "expect_note": "FastAPI 307 redirects trailing slash; quackapi 404"}
{"id": "search_happy", "method": "GET", "path": "/search?q=al&limit=2", "headers": {}, "body": null, "expect_note": "200 [alice]"}
{"id": "search_no_limit", "method": "GET", "path": "/search?q=b", "headers": {}, "body": null, "expect_note": "200 [bob]"}
{"id": "search_limit_max", "method": "GET", "path": "/search?q=a&limit=100", "headers": {}, "body": null, "expect_note": "200 limit=100 is OK (le=100)"}
{"id": "search_limit_over", "method": "GET", "path": "/search?q=a&limit=101", "headers": {}, "body": null, "expect_note": "422 less_than_equal loc=[query,limit]"}
{"id": "search_limit_999", "method": "GET", "path": "/search?q=hi&limit=999", "headers": {}, "body": null, "expect_note": "422 less_than_equal"}
{"id": "search_missing_q", "method": "GET", "path": "/search?limit=5", "headers": {}, "body": null, "expect_note": "422 missing loc=[query,q]"}
{"id": "search_limit_bad_int", "method": "GET", "path": "/search?q=a&limit=abc", "headers": {}, "body": null, "expect_note": "422 int_parsing loc=[query,limit]"}
{"id": "search_limit_float", "method": "GET", "path": "/search?q=a&limit=1.5", "headers": {}, "body": null, "expect_note": "422 int_parsing (float not valid int)"}
{"id": "search_empty_q", "method": "GET", "path": "/search?q=", "headers": {}, "body": null, "expect_note": "200 with q=empty string - all users start with empty prefix"}
{"id": "search_limit_zero", "method": "GET", "path": "/search?q=a&limit=0", "headers": {}, "body": null, "expect_note": "200 with empty result (limit=0)"}
{"id": "search_limit_neg", "method": "GET", "path": "/search?q=a&limit=-1", "headers": {}, "body": null, "expect_note": "200 or 422 - no ge constraint on limit"}
{"id": "search_no_params", "method": "GET", "path": "/search", "headers": {}, "body": null, "expect_note": "422 missing q"}
{"id": "search_repeated_param", "method": "GET", "path": "/search?q=a&q=b", "headers": {}, "body": null, "expect_note": "behavior with repeated param - quackapi takes first"}
{"id": "post_users_happy", "method": "POST", "path": "/users", "headers": {"content-type": "application/json"}, "body": "{\"name\":\"dave\",\"age\":35}", "expect_note": "201 created user with id>=100"}
{"id": "post_users_missing_age", "method": "POST", "path": "/users", "headers": {"content-type": "application/json"}, "body": "{\"name\":\"noage\"}", "expect_note": "422 missing age loc=[body,age]"}
{"id": "post_users_missing_name", "method": "POST", "path": "/users", "headers": {"content-type": "application/json"}, "body": "{\"name_typo\":\"x\",\"age\":5}", "expect_note": "422 missing name loc=[body,name]"}
{"id": "post_users_both_missing", "method": "POST", "path": "/users", "headers": {"content-type": "application/json"}, "body": "{}", "expect_note": "422 with 2 errors in detail[]"}
{"id": "post_users_bad_age_type", "method": "POST", "path": "/users", "headers": {"content-type": "application/json"}, "body": "{\"name\":\"x\",\"age\":\"notint\"}", "expect_note": "422 int_parsing loc=[body,age]"}
{"id": "post_users_age_float_str", "method": "POST", "path": "/users", "headers": {"content-type": "application/json"}, "body": "{\"name\":\"x\",\"age\":\"1.5\"}", "expect_note": "422 int_parsing"}
{"id": "post_users_null_body", "method": "POST", "path": "/users", "headers": {"content-type": "application/json"}, "body": "null", "expect_note": "422 missing both fields (null body)"}
{"id": "post_users_empty_body", "method": "POST", "path": "/users", "headers": {}, "body": "", "expect_note": "422 missing both fields (empty body)"}
{"id": "post_users_wrong_ct", "method": "POST", "path": "/users", "headers": {"content-type": "text/plain"}, "body": "{\"name\":\"x\",\"age\":5}", "expect_note": "FastAPI rejects non-JSON CT for body model; quackapi still parses"}
{"id": "post_users_array_body", "method": "POST", "path": "/users", "headers": {"content-type": "application/json"}, "body": "[{\"name\":\"x\",\"age\":5}]", "expect_note": "422 - array instead of object for body"}
{"id": "post_users_malformed_json", "method": "POST", "path": "/users", "headers": {"content-type": "application/json"}, "body": "{not json}", "expect_note": "422 - malformed JSON body"}
{"id": "post_users_ct_charset", "method": "POST", "path": "/users", "headers": {"content-type": "application/json; charset=utf-8"}, "body": "{\"name\":\"x\",\"age\":5}", "expect_note": "201 - charset suffix in CT should work"}
