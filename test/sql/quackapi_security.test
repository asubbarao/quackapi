# name: test/sql/quackapi_security.test
# description: Valsafe hardening — mixed-param cast routes CREATE (422 shape covered by validation HTTP)
# group: [sql]

require quackapi

# ---------------------------------------------------------------------------
# Mixed untyped + cast params (the valsafe P1-1 footgun).
# DuckDB reports $n as VARCHAR when mixed with untyped $q, so the pre-cast
# path skips; Execute used to 500. After the conversion→422 fix, live HTTP
# returns FastAPI-shaped 422 (see test/http/validation.test.sh). Registry-
# level contract here: the route must still CREATE / DROP cleanly.
# ---------------------------------------------------------------------------
query I
CREATE ROUTE mixed_cast GET '/mixed' AS SELECT $q AS q, $n::INTEGER AS n;
----
Route mixed_cast: GET /mixed

query II
SELECT name, method FROM quackapi_routes() WHERE name = 'mixed_cast';
----
mixed_cast	GET

# Fully-cast variant (always 422 at pre-cast path, not Execute)
query I
CREATE ROUTE cast_all GET '/cast_all' AS SELECT $q::VARCHAR AS q, $n::INTEGER AS n;
----
Route cast_all: GET /cast_all

query I
DROP ROUTE mixed_cast;
----
Dropped route mixed_cast

query I
DROP ROUTE cast_all;
----
Dropped route cast_all

query I
SELECT count(*) FROM quackapi_routes();
----
0
