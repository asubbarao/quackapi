# name: test/sql/quackapi_routes.test
# description: CREATE ROUTE / DROP ROUTE DDL and the route registry
# group: [quackapi]

require quackapi

# Registry starts empty
query I
SELECT count(*) FROM quackapi_routes();
----
0

# CREATE ROUTE registers a route
query I
CREATE ROUTE hello GET '/hello' AS SELECT 'world' AS msg;
----
Route hello: GET /hello

query IIII
SELECT name, method, pattern, status FROM quackapi_routes();
----
hello	GET	/hello	200

# Duplicate name without OR REPLACE errors
statement error
CREATE ROUTE hello GET '/other' AS SELECT 1;
----
already exists

# CREATE OR REPLACE overwrites
query I
CREATE OR REPLACE ROUTE hello GET '/hello2' AS SELECT 'world2' AS msg;
----
Route hello: GET /hello2

query I
SELECT pattern FROM quackapi_routes() WHERE name = 'hello';
----
/hello2

# Path params and STATUS clause parse
query I
CREATE ROUTE item GET '/items/:id' STATUS 201 AS SELECT $id::INT AS id;
----
Route item: GET /items/:id

query II
SELECT pattern, status FROM quackapi_routes() WHERE name = 'item';
----
/items/:id	201

# Method must be a known HTTP verb
statement error
CREATE ROUTE bad TELEPORT '/x' AS SELECT 1;
----
Unknown HTTP method

# Pattern must start with /
statement error
CREATE ROUTE bad GET 'x' AS SELECT 1;
----
must start with '/'

# DROP ROUTE removes it
query I
DROP ROUTE item;
----
Dropped route item

query I
SELECT count(*) FROM quackapi_routes();
----
1

# DROP of a missing route errors
statement error
DROP ROUTE nope;
----
does not exist

query I
DROP ROUTE hello;
----
Dropped route hello

# Multi-line handler body: any whitespace (newline/tab) after AS is accepted
query I
CREATE ROUTE multiline GET '/multi' AS
SELECT
  'ok' AS msg;
----
Route multiline: GET /multi

# Handler is stored with internal newlines collapsed only by whitespace trim at
# the edges — body still contains SELECT … AS msg (single cell; replace \n for assert)
query I
SELECT replace(handler, chr(10), ' ') FROM quackapi_routes() WHERE name = 'multiline';
----
SELECT   'ok' AS msg

query I
DROP ROUTE multiline;
----
Dropped route multiline

# STATUS + REQUIRE also tolerate newlines before AS
query I
CREATE ROUTE spaced GET '/spaced' STATUS 201
REQUIRE
site_placeholder AS SELECT 1 AS n;
----
Route spaced: GET /spaced

# REQUIRE with a non-existent scheme is allowed at CREATE (fail closed at request)
query II
SELECT require_auth, status FROM quackapi_routes() WHERE name = 'spaced';
----
site_placeholder	201

query I
DROP ROUTE spaced;
----
Dropped route spaced

# Handler SQL is validated at CREATE time (not deferred to first request)
statement error
CREATE ROUTE bad GET '/x' AS SELECT * FROM no_such_table;
----
Invalid handler SQL

# Failed CREATE must not leave a route behind
query I
SELECT count(*) FROM quackapi_routes() WHERE name = 'bad';
----
0

# CREATE OR REPLACE must not mutate the registry when validation fails
query I
CREATE ROUTE keepme GET '/keep' AS SELECT 1 AS ok;
----
Route keepme: GET /keep

statement error
CREATE OR REPLACE ROUTE keepme GET '/keep' AS SELECT * FROM no_such_table_either;
----
Invalid handler SQL

query I
SELECT handler FROM quackapi_routes() WHERE name = 'keepme';
----
SELECT 1 AS ok

query I
DROP ROUTE keepme;
----
Dropped route keepme

# Multi-chunk emission: > STANDARD_VECTOR_SIZE (2048) routes must not corrupt
loop i 0 2100

statement ok
CREATE ROUTE r${i} GET '/r${i}' AS SELECT 1;

endloop

query I
SELECT count(*) FROM quackapi_routes();
----
2100

# BODY SCHEMA clause parses and is accepted on CREATE ROUTE
query I
CREATE ROUTE with_schema POST '/with-schema'
  BODY SCHEMA '{"type":"object","properties":{"n":{"type":"integer"}}}'
  AS SELECT $n::INTEGER AS n;
----
Route with_schema: POST /with-schema

query I
SELECT count(*) FROM quackapi_routes() WHERE name = 'with_schema';
----
1

query I
DROP ROUTE with_schema;
----
Dropped route with_schema

# BODY SCHEMA after PARAM also parses
query I
CREATE ROUTE with_schema2 POST '/with-schema2'
  PARAM n INTEGER DEFAULT 0
  BODY SCHEMA '{"type":"object"}'
  AS SELECT $n::INTEGER AS n;
----
Route with_schema2: POST /with-schema2

query I
DROP ROUTE with_schema2;
----
Dropped route with_schema2

# Unterminated BODY SCHEMA errors
statement error
CREATE ROUTE bad_schema POST '/x' BODY SCHEMA '{"type":"object" AS SELECT 1;
----
Unterminated BODY SCHEMA
